# Docs internos del proceso (planes/WIP de superpowers) — fuera de git.
# Sí publicamos los entregables: fichas de feature, guía de despliegue y specs.
/docs/*
!/docs/features/
!/docs/deploy/
!/docs/DEFINITION_OF_DONE.md

# Secretos / entorno — nunca al repo
.env
.env.*
!.env.example

# Dependencias / build
node_modules/
dist/
packages/*/dist/
.next/

# Generated artifacts
apps/api/openapi.json

# User-uploaded files (served by LocalDiskFileStorage; ignored in git)
apps/api/uploads/

# Stray dev server logs
*.log
*.err

# Scratch de orquestación (ledger SDD)
.superpowers/

# Entorno local personal (scripts, seeds, docker extra) — no subir al repo
.local/
