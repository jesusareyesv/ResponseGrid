# ── ResponseGrid web (Next.js) ──────────────────────────────────────────────────

# Backend base URL used by the Next.js SERVER (Server Components / Server
# Actions / the /api/upload route). Server-to-server, so CORS does not apply.
API_URL=http://localhost:3000

# Backend base URL used by the BROWSER for client-side fetches: the map
# resource points, OAuth links and report images. Must be reachable from
# the user's browser AND allowed by the backend CORS origin (FRONTEND_URL on
# the API). In a same-origin production setup this points at the public API URL.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Auth session cookie
SESSION_MAX_AGE_SECONDS=604800
# Set to "true" in production (HTTPS) so the auth cookie is Secure.
COOKIE_SECURE=false

# Show the demo-credentials helper box on the login page. Opt-in: leave unset
# (or anything other than "true") in real deployments so demo credentials are
# never exposed. Enable it only for local demos / sandboxes.
DEMO_MODE=true
