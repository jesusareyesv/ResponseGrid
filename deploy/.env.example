# ResponseGrid — production env for the EC2 all-in-one stack.
# Copy to deploy/.env on the server and fill in the real values.
#   cp deploy/.env.example deploy/.env

# ── Postgres (the container) ──────────────────────────────────────────────────
POSTGRES_USER=reliefhub
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=reliefhub

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Internal service hostnames (docker network). The password MUST match POSTGRES_PASSWORD.
DATABASE_URL=postgres://reliefhub:CHANGE_ME_strong_db_password@postgres:5432/reliefhub
REDIS_URL=redis://redis:6379
# At least 32 chars in production (validated at boot). Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
# The public URL of the web (Vercel). Used for CORS — must be the exact origin.
FRONTEND_URL=https://your-app.vercel.app
# Send the auth cookie only over HTTPS.
COOKIE_SECURE=true

# ── File storage (S3) ─────────────────────────────────────────────────────────
FILE_STORAGE=s3
S3_BUCKET=responsegrid-uploads-CHANGE_ME
AWS_REGION=eu-west-1
# Credentials: PREFER the EC2 instance IAM role (leave these empty + set the
# instance metadata hop limit to 2 — see docs). Only set static keys if you
# cannot use a role:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── OAuth (optional — leave empty to disable social login) ─────────────────────
OAUTH_CALLBACK_BASE=https://api.yourdomain.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Caddy (automatic HTTPS) ────────────────────────────────────────────────────
# Domain pointing at the EC2 Elastic IP (A record). Caddy gets a TLS cert for it.
API_DOMAIN=api.yourdomain.com
